# Copy to .env and fill in. .env is git-ignored.

# OpenCorporates
# Optional. Without a key, the adapter still works but is rate-limited and
# returns reduced data. See https://api.opencorporates.com/
OPENCORPORATES_API_KEY=

# OpenSanctions (optional, for the bulk-export download URL or auth header)
OPENSANCTIONS_DATASET_URL=

# Equasis (https://www.equasis.org) — credentials for the maxharlow/reconcile
# `ship-imo-numbers-to-ship-details` reconciler. Format: email:password.
# Equasis hard-caps at ~500 lookups/day; exceeding twice gets a 7-day block.
EQUASIS_CREDENTIALS=

# Override the `reconcile` CLI invocation (defaults to whatever is on PATH).
# Use `npx reconcile` to avoid a global npm install.
# RECONCILE_CMD=

# Override default project paths if you want data on a different volume
# SHELLNET_DATA_DIR=/some/other/path/data

# Postgres connection for published GoldenMatch context (cluster
# memberships, list-match anchors, same-as pairs). The investigate_*
# scripts skip the GoldenMatch enrichment section if this is unset.
#
# On the project's Railway deployment, assemble the public-proxy URL via:
#   railway service Postgres
#   railway variables
# then build:
#   postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@<RAILWAY_TCP_PROXY_DOMAIN>:<RAILWAY_TCP_PROXY_PORT>/<POSTGRES_DB>
DATABASE_URL=
